# Meridian configuration (twelve-factor: config lives in the environment).
# Copy to `.env` and adjust, or export these directly. Every value has a safe
# default; the system runs with none of them set.

# ---- Backend selection ----------------------------------------------------
# Vector store: "memory" (default, zero setup) or "redis" (needs Docker Compose).
MERIDIAN_BACKEND=memory

# Embedding provider: "fake" (default, deterministic, no network), "azure", or
# "local" (real semantic embeddings via sentence-transformers, free, offline).
MERIDIAN_EMBEDDING_BACKEND=fake

# LLM provider: "fake" (default, rule-based), "azure", or "groq" (real DSPy on Groq).
MERIDIAN_LLM_BACKEND=fake

# ---- Tuning ---------------------------------------------------------------
# Embedding vector dimensionality. Must match the active provider:
# 256 for the fake provider, 384 for the local all-MiniLM-L6-v2 default,
# 1536 for Azure text-embedding-3-small, etc.
MERIDIAN_EMBEDDING_DIM=256

# Number of knowledge chunks retrieved per query.
MERIDIAN_TOP_K=5

# ---- Redis (only when MERIDIAN_BACKEND=redis) -----------------------------
REDIS_URL=redis://localhost:6379

# ---- Groq (only when MERIDIAN_LLM_BACKEND=groq) ---------------------------
# The groq backend runs the real DSPy modules (Predict + Refine) on Groq.
# Requires `pip install ".[dspy]"` and a Groq API key.
# GROQ_API_KEY=gsk_...
# GROQ_MODEL=groq/llama-3.3-70b-versatile
# GROQ_API_BASE=https://api.groq.com/openai/v1

# ---- Local sentence-transformers (only when MERIDIAN_EMBEDDING_BACKEND=local) -----
# Requires `pip install ".[local]"`. Runs fully offline once weights are cached.
# MERIDIAN_ST_MODEL=sentence-transformers/all-MiniLM-L6-v2

# ---- Azure OpenAI (only when *_BACKEND=azure) -----------------------------
# AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
# AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-small
# AZURE_OPENAI_CHAT_DEPLOYMENT=gpt-4o-mini
# AZURE_OPENAI_API_VERSION=2024-02-01
# Corporate TLS-inspecting proxy CA bundle (e.g. Zscaler), if applicable:
# CORPORATE_CA_BUNDLE=/etc/ssl/certs/corporate-ca.pem
